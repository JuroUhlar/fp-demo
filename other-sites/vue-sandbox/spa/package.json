{
  "name": "vue-sandbox-spa",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "build:cloudflare": "VITE_DISABLE_SERVER_RESULT=true pnpm build",
    "deploy:cloudflare": "pnpm build:cloudflare && pnpm dlx wrangler pages deploy dist",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@fingerprint/node-sdk": "^7.0.0",
    "@fingerprint/vue": "2.0.0",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@vitejs/plugin-vue": "^5.1.0",
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "vue-tsc": "^2.1.0"
  }
}
